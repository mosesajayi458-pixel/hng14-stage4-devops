version: "3.9"

services:
  api:
    image: {{ service_image }}
    container_name: swiftdeploy-api
    environment:
      - MODE={{ mode }}
      - APP_VERSION={{ version }}
      - APP_PORT={{ service_port }}
    networks:
      - {{ network_name }}
    restart: {{ restart_policy }}
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ service_port }}/healthz')"]
      interval: 5s
      timeout: 3s
      retries: 10
    volumes:
      - {{ log_volume }}:/logs
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true

  nginx:
    image: {{ nginx_image }}
    container_name: swiftdeploy-nginx
    ports:
      - "{{ nginx_port }}:80"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
    depends_on:
      - api
    networks:
      - {{ network_name }}
    restart: always

  opa:
    image: {{ opa_image }}
    container_name: swiftdeploy-opa
    command:
      - "run"
      - "--server"
      - "--addr=0.0.0.0:8181"
      - "--log-level=info"
      - "/policies"
    volumes:
      - ./policies:/policies:ro
    networks:
      - {{ network_name }}
    ports:
      - "127.0.0.1:8181:8181"
    restart: always
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true

networks:
  {{ network_name }}:
    driver: {{ network_driver }}

volumes:
  {{ log_volume }}: